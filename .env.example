# ------------------------------------------------------------------------------
# Reference operator backend — copy to .env and fill in.
# ------------------------------------------------------------------------------

# Server
# Using uncommon ports to avoid clashing with other local services.
PORT=4499
NODE_ENV=development

# Postgres (docker-compose brings one up on 54499 with these creds)
DATABASE_URL=postgres://operator:operator@localhost:54499/operator

# Secret used to sign access JWTs. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-openssl-rand-base64-48

# id beyond KYC
# Create a pk_live_* key at https://verify.uniicy.com/dashboard/settings/api-keys
IDBEYOND_API_URL=https://api.uniicy.com
IDBEYOND_SECRET=pk_live_replace_me
# Shared secret for webhook HMAC — configure the same value in the id beyond dashboard.
IDBEYOND_WEBHOOK_SECRET=change-me-shared-with-idbeyond-dashboard

# Where the hosted flow redirects when verification finishes.
# Must be an Apple-verified Universal Link (or a trusted web URL for non-iOS clients).
KYC_RETURN_URL=https://app.example.com/kyc/return

# Apple Sign In — populated when you enable the Apple auth route.
# AUTH_APPLE_CLIENT_ID=com.yourop.app
# AUTH_APPLE_TEAM_ID=ABCDE12345

# Email transport for magic links. In dev we log to console; production
# typically swaps in Resend / SES / Postmark.
# EMAIL_TRANSPORT=console
# RESEND_API_KEY=re_replace_me
